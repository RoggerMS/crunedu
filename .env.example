# =========================================================
# CrunEdu - entorno local
# Copia este archivo como .env si vas a ejecutar con Docker.
# =========================================================

COMPOSE_PROJECT_NAME=crunedu
NODE_ENV=development

# Apps
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_FEED_SOURCE=api
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# PostgreSQL
POSTGRES_USER=crunedu
POSTGRES_PASSWORD=crunedu_password
POSTGRES_DB=crunedu_db
DOCKER_DATABASE_URL=postgresql://crunedu:crunedu_password@postgres:5432/crunedu_db?schema=public
DATABASE_URL=postgresql://crunedu:crunedu_password@localhost:5433/crunedu_db?schema=public
LOCAL_DATABASE_URL=postgresql://crunedu:crunedu_password@localhost:5433/crunedu_db?schema=public

# Redis
REDIS_URL=redis://redis:6379
LOCAL_REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_this_local_secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_HOURS=24

# Local development flags (never enable in production)
DEV_RELAXED_AUTH=false
DEV_BYPASS_ADMIN_GATES=false

# MinIO
MINIO_ROOT_USER=crunedu_minio
MINIO_ROOT_PASSWORD=crunedu_minio_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=crunedu-local
MINIO_PUBLIC_URL=http://localhost:9000

# Mailhog
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@crunedu.local
MAILHOG_UI=http://localhost:8025

# Upload limits
AVATAR_MAX_MB=3
PRODUCT_IMAGE_MAX_MB=3
DOCUMENT_MAX_MB=10
PRODUCT_MAX_IMAGES=6
