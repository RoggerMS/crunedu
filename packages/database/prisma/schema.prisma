generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  USER
  MODERATOR
  ADMIN
}

enum CommunityRole {
  MEMBER
  MODERATOR
}

enum ContentStatus {
  PUBLISHED
  HIDDEN
  DELETED
  PENDING_REVIEW
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
  SOLD_OUT
  DELETED
}

enum InquiryStatus {
  PENDING
  CONTACTED
  RESOLVED
  CANCELLED
}

enum ProductType {
  SALE
  SERVICE
  EXCHANGE
  DONATION
  RENTAL
  REQUEST
}

enum ProductPriceType {
  FIXED
  NEGOTIABLE
  FREE
  CONTACT
  EXCHANGE
  HOURLY
  FROM
}

enum ProductCondition {
  NEW
  LIKE_NEW
  GOOD
  USED
  WITH_DETAILS
  NOT_APPLICABLE
}

enum ProductDeliveryType {
  CAMPUS
  SAFE_POINT
  PICKUP
  COORDINATED
  SHIPPING
  DIGITAL
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum UniversityContentType {
  EVENTO
  CONVOCATORIA
  TRAMITE
  SERVICIO
  GUIA
  AVISO
}

enum UniversityContentVisibility {
  PUBLICO
  OFICIAL
  SUGERIDO
}

enum DocumentVisibility {
  PUBLIC
  COMMUNITY
  PRIVATE
}

enum SuggestionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

enum UniversityItemType {
  PROCEDURE
  CALL
  EVENT
  SERVICE
  GUIDE
  NOTICE
  ACADEMIC
  PAYMENT
  SCHOLARSHIP
  CULTURE
  SPORTS
  WELLBEING
}

enum UniversityItemStatus {
  DRAFT
  PENDING_REVIEW
  SCHEDULED
  PUBLISHED
  ACTIVE
  CLOSED
  COMPLETED
  CANCELLED
  ARCHIVED
  REJECTED
}

enum UniversityItemModality {
  IN_PERSON
  ONLINE
  HYBRID
  NOT_APPLICABLE
}

enum UniversityItemPriority {
  NORMAL
  IMPORTANT
  URGENT
  CRITICAL
}

enum MomentType {
  NOW
  ALERT
  FOOD
  HUMOR
  EVENT
  CAMPUS
  COMMUNITY
  LOST_FOUND
}

enum ConversationType {
  OPEN
  STUDY
  QUESTION
  DEBATE
}

enum ConversationStatus {
  DRAFT
  WAITING
  LIVE
  ENDED
  CANCELLED
}

enum ConversationVisibility {
  PUBLIC
  UNIVERSITY
  PRIVATE
}

enum ConversationParticipantRole {
  HOST
  MODERATOR
  SPEAKER
  LISTENER
}

enum ConversationSpeakerRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ConversationRecordingStatus {
  REQUESTED
  RECORDING
  PROCESSING
  AVAILABLE
  FAILED
  DELETED
}

enum ConversationMaterialType {
  PDF
  DOCX
  PPTX
  IMAGE
  OTHER
}

enum ConversationSharedLinkType {
  MEET
  ZOOM
  TEAMS
  DISCORD
  DOCUMENT
  VIDEO
  OTHER
}

// --- 1. ESTRUCTURA ACADÉMICA ---
model University {
  id        Int      @id @default(autoincrement())
  name      String
  shortName String?  @map("short_name")
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  faculties               Faculty[]
  profiles                Profile[]
  universityAreas         UniversityArea[]
  universityCalendarItems UniversityCalendarItem[]
  conversations           Conversation[]

  @@map("universities")
}

model Faculty {
  id           Int      @id @default(autoincrement())
  universityId Int      @map("university_id")
  name         String
  slug         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  university University @relation(fields: [universityId], references: [id])
  careers    Career[]
  profiles   Profile[]

  @@unique([universityId, slug])
  @@index([universityId])
  @@map("faculties")
}

model Career {
  id        Int      @id @default(autoincrement())
  facultyId Int      @map("faculty_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  faculty  Faculty   @relation(fields: [facultyId], references: [id])
  profiles Profile[]

  @@unique([facultyId, slug])
  @@index([facultyId])
  @@map("careers")
}

// --- 2. USUARIOS, AUTENTICACIÓN Y PERFILES ---
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile                 Profile?
  communitiesCreated      Community[]
  communityMembers        CommunityMember[]
  posts                   Post[]
  questions               Question[]
  answers                 Answer[]
  answerVotes             AnswerVote[]
  documents               Document[]
  savedDocuments          SavedDocument[]
  documentRatings         DocumentRating[]
  comments                Comment[]
  reactions               Reaction[]
  savedPosts              SavedPost[]
  productsCreated         Product[]
  productFavorites        ProductFavorite[]
  productInquiries        ProductInquiry[]
  reportsMade             Report[]
  notifications           Notification[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  moderationLogs          ModerationLog[]
  moderatedReports        Report[]                 @relation("ReportModerator")
  sanctions               UserSanction[]
  followers               Follow[]                 @relation("UserFollowers")
  following               Follow[]                 @relation("UserFollowing")

  universityContents     UniversityContent[]
  universitySuggestions  UniversitySuggestion[]
  universitySavedItems   UniversitySavedItem[]
  universityReminders    UniversityReminder[]
  UniversityCalendarItem UniversityCalendarItem[]
  savedContents          UniversityContentSaved[]
  auditLogs              UniversityAuditLog[]

  moments              Moment[]
  momentBoosts         MomentBoost[]
  momentConfirmations  MomentConfirmation[]
  savedMoments         SavedMoment[]
  momentComments       MomentComment[]

  conversationsCreated            Conversation[]
  conversationParticipants        ConversationParticipant[]
  conversationSpeakerRequests     ConversationSpeakerRequest[]
  conversationSpeakerResolved     ConversationSpeakerRequest[]   @relation("SpeakerRequestResolver")
  conversationBansIssued          ConversationBan[]              @relation("ConversationBanBannedBy")
  conversationBansReceived        ConversationBan[]              @relation("ConversationBanUser")
  conversationMaterialsUploaded   ConversationMaterial[]
  conversationLinksShared         ConversationSharedLink[]
  conversationDebateStances       ConversationDebateStance[]
  conversationDebateMemberships   ConversationDebateMembership[]
  conversationDebateArguments     ConversationDebateArgument[]
  conversationInvitesCreated      ConversationInvite[]
  conversationStartSubscriptions  ConversationStartSubscription[]
  conversationCompanionProfile    ConversationCompanionProfile?

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Follow {
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followingId, createdAt(sort: Desc), followerId])
  @@index([followerId, createdAt(sort: Desc), followingId])
  @@map("follows")
}

model UserSanction {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  type      String
  reason    String
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([type])
  @@map("user_sanctions")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Profile {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  avatarUrl        String?  @map("avatar_url")
  avatarStorageKey String?  @map("avatar_storage_key")
  description      String?
  universityId     Int?     @map("university_id")
  facultyId        Int?     @map("faculty_id")
  careerId         Int?     @map("career_id")
  cycle            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id])
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  career     Career?     @relation(fields: [careerId], references: [id])

  @@index([universityId])
  @@index([facultyId])
  @@index([careerId])
  @@map("profiles")
}

// --- 3. COMUNIDADES ---
model Community {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  description String?
  rules       String?
  avatarUrl   String?       @map("avatar_url")
  coverUrl    String?       @map("cover_url")
  createdBy   Int           @map("created_by")
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  creator   User              @relation(fields: [createdBy], references: [id])
  members   CommunityMember[]
  posts     Post[]
  questions Question[]
  documents Document[]

  @@index([createdBy])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt(sort: Desc)])
  @@map("communities")
}

model CommunityMember {
  id          Int           @id @default(autoincrement())
  communityId Int           @map("community_id")
  userId      Int           @map("user_id")
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

// --- 4. CONTENIDO CORE ---
model Post {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  communityId Int?          @map("community_id")
  documentId  Int?          @map("document_id")
  title       String        @default("")
  content     String
  status      ContentStatus @default(PUBLISHED)
  inFeed      Boolean       @default(true) @map("in_feed")
  viewCount   Int           @default(0) @map("view_count")
  shareCount  Int           @default(0) @map("share_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user      User        @relation(fields: [userId], references: [id])
  community Community?  @relation(fields: [communityId], references: [id])
  document  Document?   @relation(fields: [documentId], references: [id])
  comments  Comment[]
  reactions Reaction[]
  savedBy   SavedPost[]
  reports   Report[]
  tags      PostTag[]
  images    PostImage[]
  moments   Moment[]

  @@index([userId])
  @@index([communityId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityId, status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([documentId])
  @@index([inFeed])
  @@index([status, inFeed, createdAt(sort: Desc), id(sort: Desc)])
  @@map("posts")
}

model PostImage {
  id         Int      @id @default(autoincrement())
  postId     Int      @map("post_id")
  imageUrl   String   @map("image_url")
  storageKey String   @map("storage_key")
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

model Question {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  communityId Int?          @map("community_id")
  title       String
  content     String
  status      ContentStatus @default(PUBLISHED)
  isResolved  Boolean       @default(false) @map("is_resolved")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id])
  community Community?      @relation(fields: [communityId], references: [id])
  answers   Answer[]
  images    QuestionImage[]
  reports   Report[]
  tags      QuestionTag[]

  @@index([userId])
  @@index([communityId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityId, status, createdAt(sort: Desc), id(sort: Desc)])
  @@map("questions")
}

model QuestionImage {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  imageUrl   String   @map("image_url")
  storageKey String   @map("storage_key")
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_images")
}

model Answer {
  id         Int           @id @default(autoincrement())
  questionId Int           @map("question_id")
  userId     Int           @map("user_id")
  content    String
  isUseful   Boolean       @default(false) @map("is_useful")
  status     ContentStatus @default(PUBLISHED)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id])
  reports  Report[]
  images   AnswerImage[]
  votes    AnswerVote[]

  @@index([questionId])
  @@index([userId])
  @@index([status])
  @@map("answers")
}

model Document {
  id             Int                @id @default(autoincrement())
  userId         Int                @map("user_id")
  communityId    Int?               @map("community_id")
  title          String
  description    String?
  course         String             @default("")
  cycle          String?
  fileUrl        String             @map("file_url")
  storageKey     String             @map("storage_key")
  fileType       String             @map("file_type")
  sizeBytes      Int                @map("size_bytes")
  status         ContentStatus      @default(PUBLISHED)
  visibility     DocumentVisibility @default(PUBLIC)
  materialType   String?            @map("material_type")
  originalName   String?            @map("original_name")
  mimeType       String?            @map("mime_type")
  downloadsCount Int                @default(0) @map("downloads_count")
  viewsCount     Int                @default(0) @map("views_count")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id])
  community Community?       @relation(fields: [communityId], references: [id])
  reports   Report[]
  tags      DocumentTag[]
  posts     Post[]
  savedBy   SavedDocument[]
  ratings   DocumentRating[]

  @@index([userId])
  @@index([communityId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityId, status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([visibility])
  @@index([course])
  @@map("documents")
}

// --- 5. ETIQUETAS ---
model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  posts     PostTag[]
  questions QuestionTag[]
  documents DocumentTag[]

  @@map("tags")
}

model PostTag {
  postId Int @map("post_id")
  tagId  Int @map("tag_id")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

model AnswerImage {
  id         Int      @id @default(autoincrement())
  answerId   Int      @map("answer_id")
  imageUrl   String   @map("image_url")
  storageKey String   @map("storage_key")
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
  @@map("answer_images")
}

model AnswerVote {
  id        Int      @id @default(autoincrement())
  answerId  Int      @map("answer_id")
  userId    Int      @map("user_id")
  value     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([answerId, userId])
  @@index([answerId])
  @@index([userId])
  @@map("answer_votes")
}

model QuestionTag {
  questionId Int @map("question_id")
  tagId      Int @map("tag_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
  @@map("question_tags")
}

model DocumentTag {
  documentId Int @map("document_id")
  tagId      Int @map("tag_id")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags")
}

model SavedDocument {
  documentId Int      @map("document_id")
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([documentId, userId])
  @@index([userId])
  @@map("saved_documents")
}

model DocumentRating {
  id         Int      @id @default(autoincrement())
  documentId Int      @map("document_id")
  userId     Int      @map("user_id")
  value      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@map("document_ratings")
}

// --- 6. INTERACCIONES ---
model Comment {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  userId    Int           @map("user_id")
  content   String
  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  reports Report[]

  @@index([postId])
  @@index([userId])
  @@index([status])
  @@index([postId, status, createdAt])
  @@map("comments")
}

model Reaction {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("reactions")
}

model SavedPost {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("saved_posts")
}

// --- 7. TIENDA BÁSICA ---
model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_categories")
}

model Product {
  id                Int                 @id @default(autoincrement())
  title             String
  description       String
  price             Decimal?            @db.Decimal(10, 2)
  currency          String              @default("PEN")
  categoryId        Int                 @map("category_id")
  status            ProductStatus       @default(DRAFT)
  type              ProductType         @default(SALE)
  priceType         ProductPriceType    @default(FIXED) @map("price_type")
  isNegotiable      Boolean             @default(false) @map("is_negotiable")
  condition         ProductCondition?
  deliveryType      ProductDeliveryType @default(CAMPUS) @map("delivery_type")
  campus            String?
  district          String?
  safePointId       Int?                @map("safe_point_id")
  course            String?
  brand             String?
  model             String?
  quantity          Int                 @default(1)
  stock             Int                 @default(1)
  isFeatured        Boolean             @default(false) @map("is_featured")
  contactMethod     String              @default("chat") @map("contact_method")
  whatsappMessage   String?             @map("whatsapp_message")
  viewCount         Int                 @default(0) @map("view_count")
  contactClickCount Int                 @default(0) @map("contact_click_count")
  favoriteCount     Int                 @default(0) @map("favorite_count")
  createdBy         Int                 @map("created_by")
  publishedAt       DateTime?           @map("published_at")
  deletedAt         DateTime?           @map("deleted_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  category  ProductCategory   @relation(fields: [categoryId], references: [id])
  admin     User              @relation(fields: [createdBy], references: [id])
  safePoint ProductSafePoint? @relation(fields: [safePointId], references: [id])
  images    ProductImage[]
  favorites ProductFavorite[]
  inquiries ProductInquiry[]
  reports   Report[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([status])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([type])
  @@index([deliveryType])
  @@index([safePointId])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@map("products")
}

