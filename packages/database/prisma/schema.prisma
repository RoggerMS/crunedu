// --- 8. MODERACIÓN Y NOTIFICACIONES ---
model Report {
  id          Int          @id @default(autoincrement())
  reporterId  Int          @map("reporter_id")
  reason      String
  description String?
  status      ReportStatus @default(OPEN)

  postId     Int? @map("post_id")
  commentId  Int? @map("comment_id")
  questionId Int? @map("question_id")
  answerId   Int? @map("answer_id")
  documentId Int? @map("document_id")
  productId  Int? @map("product_id")
  momentId   Int? @map("moment_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  moderatedAt   DateTime? @map("moderated_at")
  moderatedById Int?      @map("moderated_by_id")

  reporter  User      @relation(fields: [reporterId], references: [id])
  moderator User?     @relation("ReportModerator", fields: [moderatedById], references: [id])
  post      Post?     @relation(fields: [postId], references: [id])
  comment   Comment?  @relation(fields: [commentId], references: [id])
  question  Question? @relation(fields: [questionId], references: [id])
  answer    Answer?   @relation(fields: [answerId], references: [id])
  document  Document? @relation(fields: [documentId], references: [id])
  product   Product?  @relation(fields: [productId], references: [id])
  moment    Moment?   @relation(fields: [momentId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([status, createdAt(sort: Asc)])
  @@index([postId])
  @@index([commentId])
  @@index([questionId])
  @@index([answerId])
  @@index([documentId])
  @@index([productId])
  @@index([momentId])
  @@index([moderatedById])
  @@map("reports")
}

model ModerationLog {
  id          Int      @id @default(autoincrement())
  moderatorId Int      @map("moderator_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    Int      @map("entity_id")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  moderator User @relation(fields: [moderatorId], references: [id])

  @@index([moderatorId])
  @@index([entityType, entityId])
  @@map("moderation_logs")
}

model Notification {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  type          String
  title         String
  message       String
  isRead        Boolean  @default(false) @map("is_read")
  referenceId   Int?     @map("reference_id")
  referenceType String?  @map("reference_type")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// --- 9. CONTENIDO UNIVERSITARIO ---
model UniversityContent {
  id          Int                         @id @default(autoincrement())
  type        UniversityContentType       @map("type")
  title       String
  description String                      @db.Text
  area        String                      @default("")
  category    String                      @default("")
  visibility  UniversityContentVisibility @default(PUBLICO)

  categoryId   Int?    @map("category_id")
  areaId       Int?    @map("area_id")
  priority     String? @default("normal")
  sourceUrl    String? @map("source_url")
  officialUrl  String? @map("official_url")
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  modality     String? @default("presencial")
  capacity     Int?
  timezone     String  @default("America/Lima")

  statusTags  Json      @default("[]")
  startDate   DateTime?
  endDate     DateTime?
  deadline    DateTime?
  time        String?
  location    String?
  cost        String?
  icon        String?
  steps       Json?
  documents   Json?
  schedule    String?
  warning     String?
  fileUrl     String?   @map("file_url")
  fileName    String?   @map("file_name")
  fileType    String?   @map("file_type")
  fileSize    Int?      @map("file_size")
  externalUrl String?   @map("external_url")

  views      Int @default(0)
  savesCount Int @default(0) @map("saves_count")

  status    ContentStatus @default(PUBLISHED)
  deletedAt DateTime?     @map("deleted_at")
  userId    Int?          @map("user_id")
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  categoryRel UniversityCategory? @relation("ContentCategory", fields: [categoryId], references: [id])
  areaRel     UniversityArea?     @relation("ContentArea", fields: [areaId], references: [id])

  savedBy UniversityContentSaved[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
  @@index([categoryId])
  @@index([areaId])
  @@index([priority])
  @@index([type, status, createdAt(sort: Desc)])
  @@index([status, deletedAt])
  @@map("university_contents")
}

model UniversityContentSaved {
  id        Int      @id @default(autoincrement())
  contentId Int      @map("content_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  content UniversityContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
  @@map("university_content_saved")
}

model UniversityAuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  before     Json?
  after      Json?
  reason     String?
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("university_audit_logs")
}

model UniversitySuggestion {
  id          Int              @id @default(autoincrement())
  type        String
  title       String
  description String           @db.Text
  area        String           @default("")
  date        DateTime?
  location    String?
  externalUrl String?          @map("external_url")
  status      SuggestionStatus @default(PENDING)

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@index([status, createdAt(sort: Desc)])
  @@map("university_suggestions")
}

// --- 10. CALENDARIO UNIVERSITARIO ---

model UniversityCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String   @default("#6B7280")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items    UniversityCalendarItem[]
  contents UniversityContent[]      @relation("ContentCategory")

  @@map("university_categories")
}

model UniversityArea {
  id           Int      @id @default(autoincrement())
  universityId Int      @map("university_id")
  parentId     Int?     @map("parent_id")
  name         String
  slug         String
  description  String?
  icon         String?
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  website      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  university   University               @relation(fields: [universityId], references: [id], onDelete: Cascade)
  items        UniversityCalendarItem[]
  contentItems UniversityContent[]      @relation("ContentArea")

  @@unique([universityId, slug])
  @@index([universityId])
  @@map("university_areas")
}

model UniversityCalendarItem {
  id           Int  @id @default(autoincrement())
  universityId Int  @map("university_id")
  categoryId   Int  @map("category_id")
  areaId       Int? @map("area_id")
  createdById  Int  @map("created_by_id")

  type        UniversityItemType
  title       String
  slug        String                 @unique
  summary     String?
  description String                 @db.Text
  modality    UniversityItemModality @default(NOT_APPLICABLE)
  status      UniversityItemStatus   @default(PUBLISHED)
  priority    UniversityItemPriority @default(NORMAL)

  sourceUrl    String? @map("source_url")
  officialUrl  String? @map("official_url")
  locationName String? @map("location_name")
  onlineUrl    String? @map("online_url")

  price    Decimal? @db.Decimal(10, 2)
  capacity Int?

  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")
  allDay   Boolean   @default(false) @map("all_day")
  timezone String    @default("America/Lima")

  isFeatured Boolean @default(false) @map("is_featured")
  viewCount  Int     @default(0) @map("view_count")
  saveCount  Int     @default(0) @map("save_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  university University         @relation(fields: [universityId], references: [id])
  category   UniversityCategory @relation(fields: [categoryId], references: [id])
  area       UniversityArea?    @relation(fields: [areaId], references: [id])
  creator    User               @relation(fields: [createdById], references: [id])

  occurrences UniversityCalendarOccurrence[]
  savedBy     UniversitySavedItem[]
  reminders   UniversityReminder[]

  @@index([universityId])
  @@index([startsAt])
  @@index([status, type])
  @@map("university_calendar_items")
}

model UniversityCalendarOccurrence {
  id           Int                  @id @default(autoincrement())
  itemId       Int                  @map("item_id")
  startsAt     DateTime             @map("starts_at")
  endsAt       DateTime             @map("ends_at")
  allDay       Boolean              @default(false) @map("all_day")
  status       UniversityItemStatus @default(ACTIVE)
  locationName String?              @map("location_name")

  createdAt DateTime @default(now()) @map("created_at")

  item UniversityCalendarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([startsAt, endsAt])
  @@map("university_calendar_occurrences")
}

model UniversitySavedItem {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  item UniversityCalendarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([userId])
  @@map("university_saved_items")
}

model UniversityReminder {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  userId    Int      @map("user_id")
  remindAt  DateTime @map("remind_at")
  isSent    Boolean  @default(false) @map("is_sent")
  createdAt DateTime @default(now()) @map("created_at")

  item UniversityCalendarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([remindAt, isSent])
  @@map("university_reminders")
}

// --- 11. MOMENTOS ---
model Moment {
  id           Int           @id @default(autoincrement())
  userId       Int           @map("user_id")
  postId       Int?          @map("post_id")
  title        String
  description  String?
  type         MomentType    @default(NOW)
  location     String?
  status       ContentStatus @default(PUBLISHED)
  isPermanent  Boolean       @default(false) @map("is_permanent")
  expiresAt    DateTime?     @map("expires_at")
  shareCount   Int           @default(0) @map("share_count")
  viewCount    Int           @default(0) @map("view_count")
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id])
  post          Post?                @relation(fields: [postId], references: [id], onDelete: Cascade)
  media         MomentMedia[]
  tags          MomentTagAssignment[]
  boosts        MomentBoost[]
  confirmations MomentConfirmation[]
  savedBy       SavedMoment[]
  comments      MomentComment[]
  reports       Report[]

  @@index([userId])
  @@index([postId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([type])
  @@index([location])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([status, expiresAt])
  @@index([isPermanent])
  @@map("moments")
}

model MomentMedia {
  id         Int      @id @default(autoincrement())
  momentId   Int      @map("moment_id")
  imageUrl   String   @map("image_url")
  storageKey String   @map("storage_key")
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@index([momentId])
  @@map("moment_media")
}

model MomentTag {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  moments MomentTagAssignment[]

  @@map("moment_tags")
}

model MomentTagAssignment {
  momentId Int @map("moment_id")
  tagId    Int @map("tag_id")

  moment Moment    @relation(fields: [momentId], references: [id], onDelete: Cascade)
  tag    MomentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([momentId, tagId])
  @@index([tagId])
  @@map("moment_tag_assignments")
}

model MomentBoost {
  id        Int      @id @default(autoincrement())
  momentId  Int      @map("moment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([userId])
  @@map("moment_boosts")
}

model MomentConfirmation {
  id        Int      @id @default(autoincrement())
  momentId  Int      @map("moment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([userId])
  @@map("moment_confirmations")
}

model SavedMoment {
  id        Int      @id @default(autoincrement())
  momentId  Int      @map("moment_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([userId])
  @@map("saved_moments")
}

model MomentComment {
  id        Int           @id @default(autoincrement())
  momentId  Int           @map("moment_id")
  userId    Int           @map("user_id")
  content   String
  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([momentId])
  @@index([userId])
  @@index([status])
  @@index([momentId, status, createdAt])
  @@map("moment_comments")
}

// --- 12. CONVERSAR (salas de audio) ---
model Conversation {
  id                Int                  @id @default(autoincrement())
  slug              String               @unique
  type              ConversationType     @default(OPEN)
  status            ConversationStatus   @default(WAITING)
  title             String
  description       String               @default("")
  category          String               @default("")
  course            String?
  rules             String?
  visibility        ConversationVisibility @default(PUBLIC)
  maxParticipants   Int                  @default(50) @map("max_participants")
  maxSpeakers       Int                  @default(5) @map("max_speakers")
  allowListeners    Boolean              @default(true) @map("allow_listeners")
  allowRaiseHand    Boolean              @default(true) @map("allow_raise_hand")
  recordingEnabled  Boolean              @default(false) @map("recording_enabled")
  allowNewStances   Boolean              @default(true) @map("allow_new_stances")
  isLocked          Boolean              @default(false) @map("is_locked")
  tags              String[]             @default([])
  livekitRoomName   String               @unique @map("livekit_room_name")
  conclusion        String?
  createdById       Int                  @map("created_by_id")
  universityId      Int?                 @map("university_id")
  scheduledAt       DateTime?            @map("scheduled_at")
  startedAt         DateTime?            @map("started_at")
  endedAt           DateTime?            @map("ended_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  deletedAt         DateTime?            @map("deleted_at")

  creator              User                         @relation(fields: [createdById], references: [id])
  university           University?                  @relation(fields: [universityId], references: [id])
  participants         ConversationParticipant[]
  speakerRequests      ConversationSpeakerRequest[]
  invites              ConversationInvite[]
  bans                 ConversationBan[]
  materials            ConversationMaterial[]
  links                ConversationSharedLink[]
  recordings           ConversationRecording[]
  debateStances        ConversationDebateStance[]
  startSubscriptions   ConversationStartSubscription[]

  @@index([createdById])
  @@index([status])
  @@index([type])
  @@index([visibility])
  @@index([category])
  @@index([universityId])
  @@index([createdAt])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([type, status, createdAt(sort: Desc)])
  @@map("conversations")
}

model ConversationParticipant {
  id              Int                        @id @default(autoincrement())
  conversationId  Int                        @map("conversation_id")
  userId          Int                        @map("user_id")
  role            ConversationParticipantRole @default(LISTENER)
  joinedAt        DateTime                   @default(now()) @map("joined_at")
  leftAt          DateTime?                  @map("left_at")
  totalSpeakingSeconds Int                   @default(0) @map("total_speaking_seconds")
  createdAt       DateTime                   @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, role])
  @@index([leftAt])
  @@map("conversation_participants")
}

model ConversationSpeakerRequest {
  id             Int                             @id @default(autoincrement())
  conversationId Int                             @map("conversation_id")
  userId         Int                             @map("user_id")
  status         ConversationSpeakerRequestStatus @default(PENDING)
  requestedAt    DateTime                        @default(now()) @map("requested_at")
  resolvedAt     DateTime?                       @map("resolved_at")
  resolvedById   Int?                            @map("resolved_by_id")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolver     User?         @relation("SpeakerRequestResolver", fields: [resolvedById], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId, status])
  @@index([userId])
  @@map("conversation_speaker_requests")
}

model ConversationInvite {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  createdById    Int       @map("created_by_id")
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  maxUses        Int       @default(1) @map("max_uses")
  uses           Int       @default(0)
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [createdById], references: [id])

  @@index([conversationId])
  @@index([expiresAt])
  @@map("conversation_invites")
}

model ConversationBan {
  id             Int        @id @default(autoincrement())
  conversationId Int        @map("conversation_id")
  userId         Int        @map("user_id")
  bannedById     Int        @map("banned_by_id")
  reason         String?
  createdAt      DateTime   @default(now()) @map("created_at")
  expiresAt      DateTime?  @map("expires_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User          @relation("ConversationBanUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy     User          @relation("ConversationBanBannedBy", fields: [bannedById], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_bans")
}

model ConversationMaterial {
  id             Int                     @id @default(autoincrement())
  conversationId Int                     @map("conversation_id")
  title          String
  type           ConversationMaterialType @default(OTHER)
  objectKey      String                  @map("object_key")
  fileUrl        String                  @map("file_url")
  mimeType       String                  @map("mime_type")
  sizeBytes      Int                     @map("size_bytes")
  uploadedById   Int                     @map("uploaded_by_id")
  createdAt      DateTime                @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])

  @@index([conversationId])
  @@map("conversation_materials")
}

model ConversationSharedLink {
  id             Int                        @id @default(autoincrement())
  conversationId Int                        @map("conversation_id")
  title          String
  url            String
  domain         String
  type           ConversationSharedLinkType @default(OTHER)
  sharedById     Int                        @map("shared_by_id")
  createdAt      DateTime                   @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sharedBy     User          @relation(fields: [sharedById], references: [id])

  @@index([conversationId])
  @@map("conversation_shared_links")
}

model ConversationRecording {
  id              Int                          @id @default(autoincrement())
  conversationId  Int                          @map("conversation_id")
  status          ConversationRecordingStatus  @default(REQUESTED)
  objectKey       String?                      @map("object_key")
  fileUrl         String?                      @map("file_url")
  durationSeconds Int                          @default(0) @map("duration_seconds")
  sizeBytes       Int                          @default(0) @map("size_bytes")
  mimeType        String                       @default("audio/mpeg") @map("mime_type")
  plays           Int                          @default(0)
  egressId        String?                      @map("egress_id")
  errorMessage    String?                      @map("error_message")
  startedAt       DateTime?                    @map("started_at")
  endedAt         DateTime?                    @map("ended_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  deletedAt       DateTime?                    @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("conversation_recordings")
}

model ConversationDebateStance {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  title          String
  description    String?
  order          Int      @default(0)
  createdById    Int      @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy    User          @relation(fields: [createdById], references: [id])
  memberships  ConversationDebateMembership[]
  arguments    ConversationDebateArgument[]

  @@index([conversationId])
  @@map("conversation_debate_stances")
}

model ConversationDebateMembership {
  id        Int      @id @default(autoincrement())
  stanceId  Int      @map("stance_id")
  userId    Int      @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  stance ConversationDebateStance @relation(fields: [stanceId], references: [id], onDelete: Cascade)
  user   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stanceId, userId])
  @@index([userId])
  @@map("conversation_debate_memberships")
}

model ConversationDebateArgument {
  id        Int       @id @default(autoincrement())
  stanceId  Int       @map("stance_id")
  authorId  Int       @map("author_id")
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  stance ConversationDebateStance @relation(fields: [stanceId], references: [id], onDelete: Cascade)
  author User                     @relation(fields: [authorId], references: [id])

  @@index([stanceId])
  @@index([authorId])
  @@map("conversation_debate_arguments")
}

model ConversationCompanionProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique @map("user_id")
  description       String   @default("")
  topics            String[] @default([])
  courses           String[] @default([])
  availabilityText  String?  @map("availability_text")
  availableForVoice Boolean  @default(true) @map("available_for_voice")
  isActive          Boolean  @default(true) @map("is_active")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([availableForVoice])
  @@map("conversation_companion_profiles")
}

model ConversationStartSubscription {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  userId         Int       @map("user_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  notifiedAt     DateTime? @map("notified_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([notifiedAt])
  @@map("conversation_start_subscriptions")
}
